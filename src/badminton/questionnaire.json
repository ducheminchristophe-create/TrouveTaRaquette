{
  "sport": "badminton",
  "version": 1,
  "dimensions": ["power", "control", "speed", "repulsion", "comfort"],
  "_doc": "Chaque option applique des effets sur le profil utilisateur. targetDelta = ajuste le profil cible (base 50/dimension). weightMul = ajuste l'importance d'une dimension. set = fixe une variable moteur pour les filtres.",
  "questions": [
    {
      "id": "level",
      "type": "single",
      "required": true,
      "label": "Quel est ton niveau au badminton ?",
      "options": [
        { "id": "beginner",     "label": "Débutant (je découvre)",                    "effects": { "targetDelta": { "control": 15, "comfort": 15, "power": -10, "speed": 5 }, "weightMul": { "control": 1.3, "comfort": 1.3, "power": 0.7 }, "set": { "userLevelOrdinal": 0 } } },
        { "id": "intermediate", "label": "Intermédiaire (je joue régulièrement)",     "effects": { "set": { "userLevelOrdinal": 1 } } },
        { "id": "advanced",     "label": "Confirmé",                                  "effects": { "targetDelta": { "power": 8, "repulsion": 5 }, "weightMul": { "power": 1.1 }, "set": { "userLevelOrdinal": 2 } } },
        { "id": "competition",  "label": "Compétition",                               "effects": { "targetDelta": { "power": 10, "repulsion": 8, "control": -3 }, "weightMul": { "power": 1.2, "repulsion": 1.1 }, "set": { "userLevelOrdinal": 3 } } }
      ]
    },
    {
      "id": "game",
      "type": "single",
      "required": true,
      "label": "Tu joues plutôt en double ou en simple ?",
      "options": [
        { "id": "doubles", "label": "Double (réactivité, jeu rapide au filet)",       "effects": { "targetDelta": { "speed": 15, "repulsion": 8, "power": -8 }, "weightMul": { "speed": 1.3 } } },
        { "id": "singles", "label": "Simple (endurance, puissance en fond de court)", "effects": { "targetDelta": { "power": 10, "control": 8 }, "weightMul": { "power": 1.1, "control": 1.1 } } },
        { "id": "both",    "label": "Les deux",                                       "effects": {} }
      ]
    },
    {
      "id": "style",
      "type": "single",
      "required": true,
      "label": "Quel est ton style de jeu ?",
      "options": [
        { "id": "power",     "label": "Attaquant (smash, frappe forte)",               "effects": { "targetDelta": { "power": 20, "repulsion": 10, "control": -12, "speed": -5 }, "weightMul": { "power": 1.3, "repulsion": 1.1 } } },
        { "id": "speed",     "label": "Vitesse / contre-attaque (jeu rapide, filet)", "effects": { "targetDelta": { "speed": 20, "repulsion": 8, "power": -15, "control": -5 }, "weightMul": { "speed": 1.4, "repulsion": 1.1 } } },
        { "id": "control",   "label": "Placement / défense (précision, rallyes)",     "effects": { "targetDelta": { "control": 20, "comfort": 8, "power": -15, "speed": -5 }, "weightMul": { "control": 1.4 } } },
        { "id": "all_round", "label": "Polyvalent (un peu de tout)",                  "effects": { "weightMul": { "control": 1.1, "speed": 1.1 } } }
      ]
    },
    {
      "id": "priority",
      "type": "single",
      "required": true,
      "label": "Si tu devais choisir UNE priorité ?",
      "options": [
        { "id": "power",     "label": "La puissance (smash dévastateur)",             "effects": { "targetDelta": { "power": 10 }, "weightMul": { "power": 1.6 } } },
        { "id": "speed",     "label": "La vitesse (réactivité, jeu rapide)",           "effects": { "targetDelta": { "speed": 10 }, "weightMul": { "speed": 1.6 } } },
        { "id": "control",   "label": "Le contrôle (précision, placement)",           "effects": { "targetDelta": { "control": 10 }, "weightMul": { "control": 1.6 } } },
        { "id": "repulsion", "label": "La répulsion (drives rapides, contre-attaque)","effects": { "targetDelta": { "repulsion": 10 }, "weightMul": { "repulsion": 1.6 } } },
        { "id": "comfort",   "label": "Le confort (raquette facile à utiliser)",       "effects": { "targetDelta": { "comfort": 10 }, "weightMul": { "comfort": 1.6 } } }
      ]
    },
    {
      "id": "shoulder",
      "type": "single",
      "required": true,
      "label": "As-tu des douleurs à l'épaule, au coude ou au poignet ?",
      "_doc": "Critère important : oriente vers les raquettes flexible + légères et impose un seuil de confort minimal.",
      "options": [
        { "id": "often",     "label": "Oui, c'est un vrai sujet pour moi",           "effects": { "targetDelta": { "comfort": 30, "power": -10 }, "weightMul": { "comfort": 2.0, "power": 0.7 }, "set": { "requireComfortMin": 60 } } },
        { "id": "sometimes", "label": "Parfois / je préfère prévenir",               "effects": { "targetDelta": { "comfort": 15 }, "weightMul": { "comfort": 1.4 } } },
        { "id": "never",     "label": "Non, aucun souci",                             "effects": {} }
      ]
    },
    {
      "id": "physique",
      "type": "single",
      "required": true,
      "label": "Comment décrirais-tu ta force / ta vitesse de bras ?",
      "options": [
        { "id": "light",  "label": "Plutôt léger / bras fin",                         "effects": { "targetDelta": { "speed": 12, "power": -8 }, "weightMul": { "speed": 1.2 }, "set": { "preferWeightMax": 82 } } },
        { "id": "medium", "label": "Moyen",                                            "effects": {} },
        { "id": "strong", "label": "Costaud / bonne vitesse de bras",                 "effects": { "targetDelta": { "power": 10, "repulsion": 5 }, "weightMul": { "power": 1.1 } } }
      ]
    },
    {
      "id": "budget",
      "type": "single",
      "required": true,
      "label": "Quel est ton budget maximum ?",
      "options": [
        { "id": "u50",     "label": "Jusqu'à 50 €",   "effects": { "set": { "maxPrice": 50 } } },
        { "id": "u100",    "label": "Jusqu'à 100 €",  "effects": { "set": { "maxPrice": 100 } } },
        { "id": "u150",    "label": "Jusqu'à 150 €",  "effects": { "set": { "maxPrice": 150 } } },
        { "id": "nolimit", "label": "Pas de limite",  "effects": {} }
      ]
    },
    {
      "id": "singles_doubles_hint",
      "type": "single",
      "required": false,
      "label": "En double, tu joues plutôt côté gauche ou côté droit ? (optionnel)",
      "options": [
        { "id": "right", "label": "Côté droit (avant / filet)", "effects": { "targetDelta": { "speed": 5, "repulsion": 5 } } },
        { "id": "left",  "label": "Côté gauche (arrière / smash)", "effects": { "targetDelta": { "power": 8 } } },
        { "id": "any",   "label": "Peu importe / simple",         "effects": {} }
      ]
    }
  ]
}
