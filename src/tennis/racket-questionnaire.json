        { "id": "light",      "label": "280-295 g",      "effects": { "set": { "targetWeightCat": "light" }, "weightMul": { "maneuverability": 1.2 } } },
        { "id": "medium",     "label": "300-305 g",      "effects": { "set": { "targetWeightCat": "medium" } } },
