{
  "sport": "tennis-racket",
  "version": 2,
  "questions": [
    {
      "id": "experience",
      "section": "Profil du joueur",
      "required": true,
      "label": "As-tu déjà pratiqué le tennis ?",
      "options": [
        { "id": "never",        "label": "Jamais",        "effects": { "set": { "levelOrdinal": 0, "targetForgiveness": 90, "targetManeuverability": 88 } } },
        { "id": "beginner",     "label": "Débutant",      "effects": { "set": { "levelOrdinal": 0, "targetForgiveness": 88, "targetManeuverability": 85 } } },
        { "id": "intermediate", "label": "Intermédiaire", "effects": { "set": { "levelOrdinal": 2 } } },
        { "id": "advanced",     "label": "Confirmé",      "effects": { "set": { "levelOrdinal": 3, "targetControl": 82, "targetPrecision": 80 } } },
        { "id": "competitor",   "label": "Compétiteur",   "effects": { "set": { "levelOrdinal": 3, "targetControl": 88, "targetPrecision": 85, "targetStability": 85 } } }
      ]
    },
    {
      "id": "age",
      "section": "Profil du joueur",
      "required": true,
      "label": "Quel âge as-tu ?",
      "options": [
        { "id": "u18",   "label": "Moins de 18 ans", "effects": { "set": { "preferLight": true }, "weightMul": { "maneuverability": 1.3 }, "targetDelta": { "maneuverability": 8 } } },
        { "id": "18_35", "label": "18 – 35 ans",     "effects": {} },
        { "id": "36_50", "label": "36 – 50 ans",     "effects": { "targetDelta": { "comfort": 5 }, "weightMul": { "comfort": 1.1 } } },
        { "id": "o50",   "label": "Plus de 50 ans",  "effects": { "set": { "preferLight": true }, "targetDelta": { "comfort": 10, "forgiveness": 10, "maneuverability": 8 }, "weightMul": { "comfort": 1.3, "forgiveness": 1.3, "maneuverability": 1.2 } } }
      ]
    },
    {
      "id": "gender",
      "section": "Profil du joueur",
      "required": true,
      "label": "Homme ou femme ?",
      "options": [
        { "id": "male",   "label": "Homme", "effects": {} },
        { "id": "female", "label": "Femme", "effects": { "set": { "preferLight": true }, "targetDelta": { "maneuverability": 6, "comfort": 5 }, "weightMul": { "maneuverability": 1.2, "comfort": 1.1 } } },
        { "id": "other",  "label": "Autre", "effects": {} }
      ]
    },
    {
      "id": "height",
      "section": "Profil du joueur",
      "required": true,
      "label": "Quelle est ta taille ?",
      "options": [
        { "id": "u160", "label": "Moins de 160 cm", "effects": { "set": { "preferLight": true }, "targetDelta": { "maneuverability": 8 }, "weightMul": { "maneuverability": 1.2 } } },
        { "id": "160_170", "label": "160 – 170 cm", "effects": { "targetDelta": { "maneuverability": 4 }, "weightMul": { "maneuverability": 1.1 } } },
        { "id": "170_180", "label": "170 – 180 cm", "effects": {} },
        { "id": "180_190", "label": "180 – 190 cm", "effects": { "targetDelta": { "stability": 5 }, "weightMul": { "stability": 1.1 } } },
        { "id": "o190",    "label": "Plus de 190 cm","effects": { "targetDelta": { "stability": 8, "power": 5 }, "weightMul": { "stability": 1.2 } } }
      ]
    },
    {
      "id": "weight_player",
      "section": "Profil du joueur",
      "required": true,
      "label": "Quel est ton poids ?",
      "options": [
        { "id": "u60",  "label": "Moins de 60 kg", "effects": { "set": { "preferLight": true }, "targetDelta": { "maneuverability": 8, "comfort": 5 }, "weightMul": { "maneuverability": 1.2 } } },
        { "id": "60_75","label": "60 – 75 kg",     "effects": { "targetDelta": { "maneuverability": 4 }, "weightMul": { "maneuverability": 1.1 } } },
        { "id": "75_90","label": "75 – 90 kg",     "effects": {} },
        { "id": "o90",  "label": "Plus de 90 kg",  "effects": { "targetDelta": { "stability": 8, "power": 5 }, "weightMul": { "stability": 1.2 }, "set": { "preferHeavy": true } } }
      ]
    },
    {
      "id": "frequency",
      "section": "Fréquence de jeu",
      "required": true,
      "label": "Combien de fois joues-tu par semaine ?",
      "options": [
        { "id": "rarely",    "label": "Moins d'1 fois",  "effects": { "weightMul": { "forgiveness": 1.3, "comfort": 1.2 } } },
        { "id": "weekly",    "label": "1 à 2 fois",      "effects": {} },
        { "id": "regular",   "label": "3 à 4 fois",      "effects": { "weightMul": { "control": 1.1, "stability": 1.1 } } },
        { "id": "intensive", "label": "5 fois et plus",  "effects": { "weightMul": { "control": 1.2, "stability": 1.2, "precision": 1.1 } } }
      ]
    },
    {
      "id": "competition",
      "section": "Fréquence de jeu",
      "required": true,
      "label": "Participes-tu à des compétitions ?",
      "options": [
        { "id": "no",           "label": "Non",              "effects": {} },
        { "id": "occasional",   "label": "Occasionnellement","effects": { "weightMul": { "control": 1.1 } } },
        { "id": "regular_comp", "label": "Régulièrement",    "effects": { "weightMul": { "control": 1.2, "precision": 1.2, "stability": 1.1 } } }
      ]
    },
    {
      "id": "play_style",
      "section": "Style de jeu",
      "required": true,
      "label": "Te considères-tu comme :",
      "options": [
        { "id": "defensive",  "label": "Défensif",    "effects": { "targetDelta": { "maneuverability": 10, "comfort": 8 }, "weightMul": { "maneuverability": 1.3, "forgiveness": 1.2 } } },
        { "id": "allround",   "label": "Polyvalent",  "effects": { "targetDelta": { "control": 5 }, "weightMul": { "stability": 1.1 } } },
        { "id": "offensive",  "label": "Offensif",    "effects": { "targetDelta": { "power": 12, "spin": 8 }, "weightMul": { "power": 1.3, "stability": 1.2 } } }
      ]
    },
    {
      "id": "court_position",
      "section": "Style de jeu",
      "required": true,
      "label": "Où joues-tu le plus souvent ?",
      "options": [
        { "id": "baseline", "label": "Fond de court", "effects": { "targetDelta": { "power": 8, "spin": 5 }, "weightMul": { "power": 1.2, "stability": 1.2 } } },
        { "id": "midcourt", "label": "Mi-court",      "effects": { "targetDelta": { "control": 8 }, "weightMul": { "control": 1.2 } } },
        { "id": "net",      "label": "Filet",         "effects": { "targetDelta": { "maneuverability": 10, "precision": 8 }, "weightMul": { "maneuverability": 1.3, "precision": 1.2 } } }
      ]
    },
