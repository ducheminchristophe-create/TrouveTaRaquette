        { "id": "wrist",    "label": "Poignet", "effects": { "targetDelta": { "comfort": 15 }, "weightMul": { "comfort": 1.6 }, "set": { "requireArmFriendly": true } } },
        { "id": "none",     "label": "Aucune",  "effects": {} }
