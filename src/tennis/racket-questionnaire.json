        { "id": "feel",      "label": "Beaucoup de sensations", "effects": { "targetDelta": { "precision": 12, "control": 8 }, "weightMul": { "precision": 1.4 } } },
        { "id": "some_feel", "label": "Un peu de sensations",   "effects": { "targetDelta": { "control": 5 } } },
