# TrouveTaRaquette — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs réelles (ne jamais commiter .env.local)

# -------------------------------------------------------
# MODE DÉMO — mettre à "true" pendant le développement
# pour désactiver tous les appels à l'API OpenAI.
# Mettre à "false" (ou supprimer) pour la production.
# -------------------------------------------------------
NEXT_PUBLIC_DEMO_MODE=true

# Clé API OpenAI pour les recommandations de cordage tennis
# Obtenir sur : https://platform.openai.com/api-keys
NEXT_PUBLIC_AI_API_KEY=your_openai_api_key_here

# URL de base de l'API (laisser la valeur par défaut pour OpenAI)
NEXT_PUBLIC_AI_API_URL=https://api.openai.com/v1

# --- Paramètres d'affiliation (optionnels — laisser vide si non configuré) ---
# Décathlon Affiliés : https://affiliates.decathlon.com
NEXT_PUBLIC_AFF_DECATHLON=

# Amazon Partenaires : https://partenaires.amazon.fr
NEXT_PUBLIC_AFF_AMAZON=

# TradeInn / Smashinn
NEXT_PUBLIC_AFF_TRADEINN=

# Padel Nuestro
NEXT_PUBLIC_AFF_PADELNUESTRO=

# Badminton Planet
NEXT_PUBLIC_AFF_BADMINTONPLANET=

# Badminton Shop
NEXT_PUBLIC_AFF_BADMINTON_SHOP=

# --- Capture e-mail (optionnel) ---
# URL de ton endpoint d'emailing (Brevo, Mailchimp, Loops, ConvertKit…)
# Laisser vide pour désactiver le composant EmailCapture
NEXT_PUBLIC_EMAIL_API_URL=
